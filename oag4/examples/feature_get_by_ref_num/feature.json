				"name": "CLONE -Automation of FON-21345-  Inconsistent behavior UI vs API for File Upload with spaces in filename",
				"reference_num": "FON-910-1",
				"position": 1,
				"created_at": "2025-05-28T11:39:30.078Z",
				"updated_at": "2025-06-10T10:24:38.991Z",
