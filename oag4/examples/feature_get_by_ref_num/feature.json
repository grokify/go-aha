		"custom_fields": [
			{
				"id": "7508808011456071916",
				"key": "problem_statement",
				"name": "Background / Context / Problem Summary",
				"updatedAt": "2025-05-27T18:51:38Z",
				"body": "\u003cp\u003eIssue is that we are unable to delete some files in filedirectory/success folder. We raised a ticket #INC-2057522 for the same issue\u003c/p\u003e\u003cp\u003eThrough the ticket we got an update that as these files are being placed when an external jar is running so we are not able to delete the files from UI level. Request to provide the feasibility to delete the files from UI level.\u003c/p\u003e\u003cp\u003eAs the jobs are running daily reports are being placed in the success folder. As we are not able to delete the files. this will cause a space issue which leads to job failures. So request you to check and implement this solution.\u003c/p\u003e\u003cp\u003ePlease test this in our Dev environment first before moving to Prod. Please let me know in case of any queries.\u003c/p\u003e",
				"editor_version": 1,
				"created_at": "2025-05-26T17:30:02.380Z",
				"updated_at": "2025-05-27T18:51:38.111Z",
				"attachments": [],
				"value": "\u003cp\u003eIssue is that we are unable to delete some files in filedirectory/success folder. We raised a ticket #INC-2057522 for the same issue\u003c/p\u003e\u003cp\u003eThrough the ticket we got an update that as these files are being placed when an external jar is running so we are not able to delete the files from UI level. Request to provide the feasibility to delete the files from UI level.\u003c/p\u003e\u003cp\u003eAs the jobs are running daily reports are being placed in the success folder. As we are not able to delete the files. this will cause a space issue which leads to job failures. So request you to check and implement this solution.\u003c/p\u003e\u003cp\u003ePlease test this in our Dev environment first before moving to Prod. Please let me know in case of any queries.\u003c/p\u003e",
				"type": "note"
			},
